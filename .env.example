# XP concedido a cada jogador vivo, a cada segundo (durante a partida)
XP_PER_SECOND=5
# XP passivo por segundo para bots vivos
BOT_XP_PER_SECOND=15
# IA dos bots (false = ficam parados e não atacam)
BOT_AI_ENABLED=true
# Bot escolhe habilidade aleatória no level-up e os outros esperam (false = resolve na hora)
BOT_LEVELUP_CHOICE_ENABLED=true
# PvP: true = jogadores/bots se atacam. false = PvE (só mobs; bots não atacam jogadores) — padrão
PVP_ENABLED=false

# Tempo máximo (segundos) na tela de escolha de magia (0 = sem limite)
LEVELUP_CHOICE_TIMEOUT=10

# XP concedido a cada monstro vivo, a cada segundo (durante a partida)
MONSTER_XP_PER_SECOND=3
# XP que o monstro ganha ao eliminar um jogador
MONSTER_XP_PLAYER_KILL=100
# Monstros vivos permanecem no próximo round (true/false)
MONSTER_PERSIST_ROUNDS=true
# Dificuldade da partida: easy | normal | hard | nightmare | apocalypse
# Escala HP/dano dos mobs, spawn, peso de elites e bosses.
DIFFICULTY=normal

# Spawn de monstros (false = não gera novos mobs)
MONSTER_SPAWN_ENABLED=true
# Spawn: intervalo (segundos), quantidade por tick, pesos e diversidade
MONSTER_SPAWN_INTERVAL=3
MONSTER_SPAWN_COUNT=3
MONSTER_WEIGHT_COMMON=10
MONSTER_WEIGHT_ELITE=5
MONSTER_WEIGHT_BOSS=6
MONSTER_SPAWN_DIVERSITY=1
# Boss fight por duração da partida: após o round N, chance % de iniciar a luta (sem tempo).
# Formato: "round#chance%" (vírgula para vários). Aspas obrigatórias — # seria comentário no .env.
# Ex.: "5#100%" = 100% de boss spawn após o round 5 numa partida de 5 rounds.
BOSS_APPEARS_1="1#100%"
BOSS_APPEARS_5="5#100%"
BOSS_APPEARS_10="5#100%,10#100%"
BOSS_APPEARS_15="5#100%,10#100%,15#100%"
BOSS_APPEARS_20="5#100%,10#100%,15#100%,20#100%"
# Auto-cura do boss: intervalo (s), chance (0–1) e % máx. da vida máxima por cura
BOSS_HEAL_INTERVAL=5
BOSS_HEAL_CHANCE=0.1
BOSS_HEAL_MAX_PERCENT=0.6
# Chance (0–1) do mob dropar moeda em vez do saco de loot
MONSTER_COIN_DROP_CHANCE=0.45
# Gold por moeda coletada
COIN_VALUE=1

# Regeneração de vida: pontos por janela e intervalo em segundos
HP_REGEN_AMOUNT=2
HP_REGEN_INTERVAL=2
# Cura ao matar mob: fração da vida máxima do mob (0–1). Ex.: 0.1 = 10%. 0 = desligado
MONSTER_KILL_HEAL_PERCENT=0.1
# Por nível do personagem (nível 1 = base): vida máxima, cura (H) e escudo (E)
PLAYER_HP_PER_LEVEL=10
PLAYER_HEAL_PER_LEVEL=4
PLAYER_SHIELD_PER_LEVEL=5

# Velocidade de movimento (px/s): jogadores/bots e base dos mobs
PLAYER_SPEED=189
MONSTER_SPEED=95

# Inércia do movimento (segundos para aproximar da velocidade alvo; 0 = instantâneo)
PLAYER_INERTIA=0.90
MONSTER_INERTIA=1.18

# Dash (Shift + WASD): velocidade (px/s), duração e cooldown (segundos)
PLAYER_DASH_SPEED=520
PLAYER_DASH_DURATION=0.12
PLAYER_DASH_COOLDOWN=0.7
# Ultimate: cooldown em segundos (autocast quando fora de CD)
PLAYER_ULTIMATE_COOLDOWN=20

# Partida: quantidade de rounds e duração de cada um (segundos)
MAX_ROUNDS=5
ROUND_DURATION=60

# Arena: raio inicial (px), intervalo entre início dos encolhimentos, duração do
# fechamento gradual e quantas vezes encolhe por round (a duração do round deve
# cobrir INTERVAL × TIMES)
ARENA_START_RADIUS=384
ARENA_SHRINK_INTERVAL=10
ARENA_SHRINK_DURATION=5
ARENA_SHRINK_TIMES=5

# Duração do fade-out do pentagrama ao lançar magia (segundos)
PENTAGRAM_FADEOUT=0.35

# Empurrão ao ser atingido por magia projétil (desligado por padrão)
# Magias em área (nova, nuvem, etc.) não empurram
PROJECTILE_KNOCKBACK_ENABLED=false
PROJECTILE_KNOCKBACK_SPEED=280
PROJECTILE_KNOCKBACK_DURATION=0.12

# Cooldown global entre eventos de arena (meteoro / heal / névoa / ventania / alavanca).
# Depois que um evento começa, só outro após este tempo (segundos). 0 = off.
ARENA_EVENT_COOLDOWN=30

# Meteoro aleatório: intervalo min/max entre eventos (segundos)
# (~25% menos frequente que 5–10)
METEOR_EVENT_MIN_INTERVAL=7
METEOR_EVENT_MAX_INTERVAL=13
# Tempo de aviso (círculo) e duração do impacto visual (segundos)
METEOR_WARN_TIME=1.2
METEOR_IMPACT_TIME=0.85
# Área (raio em px) e dano do meteoro
METEOR_RADIUS=150
METEOR_DAMAGE=42

# Mass heal aleatório: mesmos parâmetros do meteoro (cura em vez de dano)
MASS_HEAL_EVENT_MIN_INTERVAL=7
MASS_HEAL_EVENT_MAX_INTERVAL=13
MASS_HEAL_WARN_TIME=1.2
MASS_HEAL_IMPACT_TIME=0.85
MASS_HEAL_RADIUS=150
MASS_HEAL_AMOUNT=42

# Névoa de cooldown aleatória: mesmos parâmetros (reduz CDs na área)
COOLDOWN_MIST_EVENT_MIN_INTERVAL=7
COOLDOWN_MIST_EVENT_MAX_INTERVAL=13
COOLDOWN_MIST_WARN_TIME=1.2
COOLDOWN_MIST_IMPACT_TIME=0.85
COOLDOWN_MIST_RADIUS=150
# Fração de redução dos cooldowns restantes (0.3 = 30%)
COOLDOWN_MIST_REDUCTION=0.3

# Ventania aleatória: +50% velocidade / −25% inércia na área
GALE_EVENT_MIN_INTERVAL=7
GALE_EVENT_MAX_INTERVAL=13
GALE_WARN_TIME=1.2
GALE_DURATION=5
GALE_RADIUS=150
GALE_SPEED_MUL=1.5
GALE_INERTIA_MUL=0.75

# Alavanca aleatória: ao passar por cima, a arena cresce (fração do shrink por fase)
LEVER_EVENT_MIN_INTERVAL=10
LEVER_EVENT_MAX_INTERVAL=10
LEVER_APPEAR_TIME=0.45
LEVER_LIFETIME=14
LEVER_PULL_TIME=0.55
LEVER_RADIUS=22
LEVER_EXPAND_RATIO=0.5

# Vozes aleatórias (Kiko / Seu Madruga): intervalo min/max (s) e chance (0–1)
KIKO_LAUGH_MIN_INTERVAL=5
KIKO_LAUGH_MAX_INTERVAL=10
KIKO_LAUGH_CHANCE=0.5


# Banco de dados (Sequelize)
DB_DIALECT=sqlite
DATABASE_URL=sqlite:./data/wizard_arena.sqlite
# Railway (recomendado): adicione o plugin Postgres e use:
# DB_DIALECT=postgres
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# SQLite no Railway perde dados no redeploy (disco efêmero), a menos que use Volume.
