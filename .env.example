# XP concedido a cada jogador vivo, a cada segundo (durante a partida)
XP_PER_SECOND=5
# XP passivo por segundo para bots vivos
BOT_XP_PER_SECOND=5

# Regeneração de vida: pontos por janela e intervalo em segundos
HP_REGEN_AMOUNT=2
HP_REGEN_INTERVAL=2

# Velocidade de movimento (px/s): jogadores/bots e base dos mobs
PLAYER_SPEED=180
MONSTER_SPEED=95

# Inércia do movimento (segundos para aproximar da velocidade alvo; 0 = instantâneo)
PLAYER_INERTIA=0.12
MONSTER_INERTIA=0.18

# Dificuldade: easy | normal | hard | nightmare | apocalypse
DIFFICULTY=normal

# Spawn de monstros: intervalo (segundos), quantidade por tick, pesos e diversidade
MONSTER_SPAWN_INTERVAL=4
MONSTER_SPAWN_COUNT=1
MONSTER_WEIGHT_COMMON=10
MONSTER_WEIGHT_ELITE=5
MONSTER_WEIGHT_BOSS=6
MONSTER_SPAWN_DIVERSITY=1
# Rounds em que o boss aparece (separados por vírgula). Round de boss sem tempo.
BOSS_APPEARS=1,10,20
# Auto-cura do boss: intervalo (s), chance (0–1) e % máx. da vida máxima por cura
BOSS_HEAL_INTERVAL=5
BOSS_HEAL_CHANCE=0.1
BOSS_HEAL_MAX_PERCENT=0.6

# Dash (Shift + WASD): velocidade (px/s), duração e cooldown (segundos)
PLAYER_DASH_SPEED=520
PLAYER_DASH_DURATION=0.12
PLAYER_DASH_COOLDOWN=0.7

# Partida: quantidade de rounds e duração de cada um (segundos)
MAX_ROUNDS=5
ROUND_DURATION=60

# Arena: raio inicial (px), intervalo entre início dos encolhimentos, duração do
# fechamento gradual e quantas vezes encolhe por round (a duração do round deve
# cobrir INTERVAL × TIMES)
ARENA_START_RADIUS=320
ARENA_SHRINK_INTERVAL=10
ARENA_SHRINK_DURATION=5
ARENA_SHRINK_TIMES=5

# Duração do fade-out do pentagrama ao lançar magia (segundos)
PENTAGRAM_FADEOUT=1.76

# Empurrão ao ser atingido por magia projétil (desligado por padrão)
# Magias em área (nova, nuvem, etc.) não empurram
PROJECTILE_KNOCKBACK_ENABLED=false
PROJECTILE_KNOCKBACK_SPEED=280
PROJECTILE_KNOCKBACK_DURATION=0.12

# Meteoro aleatório: intervalo min/max, aviso, impacto, área e dano
METEOR_EVENT_MIN_INTERVAL=12
METEOR_EVENT_MAX_INTERVAL=24
METEOR_WARN_TIME=2.2
METEOR_IMPACT_TIME=0.85
METEOR_RADIUS=78
METEOR_DAMAGE=42

# Mass heal aleatório: mesmos parâmetros (cura jogadores/bots na área)
MASS_HEAL_EVENT_MIN_INTERVAL=12
MASS_HEAL_EVENT_MAX_INTERVAL=24
MASS_HEAL_WARN_TIME=2.2
MASS_HEAL_IMPACT_TIME=0.85
MASS_HEAL_RADIUS=78
MASS_HEAL_AMOUNT=42

# Névoa de cooldown aleatória: mesmos parâmetros (reduz CDs na área)
COOLDOWN_MIST_EVENT_MIN_INTERVAL=12
COOLDOWN_MIST_EVENT_MAX_INTERVAL=24
COOLDOWN_MIST_WARN_TIME=2.2
COOLDOWN_MIST_IMPACT_TIME=0.85
COOLDOWN_MIST_RADIUS=78
# Fração de redução dos cooldowns restantes (0.3 = 30%)
COOLDOWN_MIST_REDUCTION=0.3

# Ventania aleatória: +velocidade / −inércia enquanto estiver na área
GALE_EVENT_MIN_INTERVAL=12
GALE_EVENT_MAX_INTERVAL=24
GALE_WARN_TIME=2.2
GALE_DURATION=5
GALE_RADIUS=78
GALE_SPEED_MUL=1.5
GALE_INERTIA_MUL=0.75

# Risada do Kiko: intervalo min/max entre tentativas (segundos) e chance (0–1)
KIKO_LAUGH_MIN_INTERVAL=25
KIKO_LAUGH_MAX_INTERVAL=55
KIKO_LAUGH_CHANCE=0.35

# Banco de dados (Sequelize)
# sqlite: caminho do arquivo | postgres/mysql: connection string
DB_DIALECT=sqlite
DATABASE_URL=sqlite:./data/wizard_arena.sqlite
